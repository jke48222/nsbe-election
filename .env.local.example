# Supabase credentials — get from your Supabase project dashboard
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY

# Service role key — NEVER expose to client. Used for admin API routes & seeding.
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# Room PIN voters enter to join the election
NEXT_PUBLIC_ROOM_PIN=1975

# Admin password for the /admin dashboard
ADMIN_PASSWORD=nsbe2026admin
